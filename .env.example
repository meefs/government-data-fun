# OpenGovDash — optional environment variables (self-hoster backend only).
# The GitHub Pages deployment does not read this file; user API keys live in the browser.

# Flask backend (webapp/app.py)
FLASK_DEBUG=false
PORT=5000

# Optional: if you want the self-hoster backend to hardcode a data.gov / NASA / FEC key
# so users don't need to paste one. Leave unset to require per-user keys.
# DATAGOV_API_KEY=
# NASA_API_KEY=
# FEC_API_KEY=
# SAM_API_KEY=
